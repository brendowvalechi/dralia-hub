# ============================================================
# P3F Hub — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores
# ============================================================

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=dralia_user
POSTGRES_PASSWORD=troque-por-senha-forte
POSTGRES_DB=dralia

# URL usada pelo backend e pelo Alembic (dentro do Docker: host=postgres)
DATABASE_URL=postgresql://dralia_user:troque-por-senha-forte@postgres:5432/dralia

# ── Redis ────────────────────────────────────────────────────
# DB 0 → Celery broker/backend
# DB 6 → Evolution API cache (configurado no docker-compose)
REDIS_URL=redis://redis:6379/0

# ── JWT ─────────────────────────────────────────────────────
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=troque-por-chave-secreta-longa
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Evolution API ────────────────────────────────────────────
# URL interna (dentro do Docker) — não exposta ao público
EVOLUTION_API_URL=http://evolution-api:8080
# Chave de autenticação — defina também em AUTHENTICATION_API_KEY no compose
EVOLUTION_API_KEY=troque-por-chave-evolution

# ── Grafana ──────────────────────────────────────────────────
# Acesso: http://seu-dominio/grafana/ (user/senha abaixo)
GRAFANA_USER=admin
GRAFANA_PASSWORD=troque-por-senha-grafana

# ── Banco de teste (pytest) ───────────────────────────────────
# Para rodar testes de integração localmente (sem Docker):
# TEST_DATABASE_URL=postgresql+asyncpg://dralia_user:senha@localhost:5432/dralia_test
